{
  "name": "template-node",
  "description": "A template for esm Bun projects using typescript",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "Mike Valeriano <mkvlrn@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:mkvlrn/template-bun"
  },
  "keywords": [
    "bun",
    "typescript",
    "esm",
    "template"
  ],
  "scripts": {
    "dev": "bun --watch ./src/main.ts",
    "start": "bun ./src/main.ts",
    "lint": "bun lint-check --write",
    "lint-check": "biome check --diagnostic-level=warn --no-errors-on-unmatched",
    "typecheck": "tsc",
    "typecheck-staged": "tsc-files",
    "test-staged": "bun test related --bail --reporter=dots",
    "test-ci": "bun test --bail --reporter=dots",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@mkvlrn/config": "^4.0.4",
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.10",
    "tsc-files": "^1.1.4",
    "typescript": "^7.0.2"
  }
}

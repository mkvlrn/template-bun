{
  "name": "template-bun",
  "description": "A template for Bun projects",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "Mike Valeriano <mkvlrn@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:mkvlrn/template-bun"
  },
  "keywords": ["bun", "template"],
  "scripts": {
    "types": "tsc --noEmit",
    "coverage": "rm -rf coverage && bun test --coverage --coverage-reporter=lcov",
    "prepare": "husky",
    "dev": "bun --watch src/main.ts",
    "lint": "eslint --fix src tests",
    "format": "prettier --write src tests",
    "start": "bun run src/main.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@mkvlrn/tsconfig": "^0.0.5",
    "@types/bun": "^1.1.9",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "typescript": "^5.6.2"
  }
}
